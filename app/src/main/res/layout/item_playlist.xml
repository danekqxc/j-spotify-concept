<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:background="@color/spotify_black">

    <ImageView
        android:id="@+id/item_playlist_cover"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"
        android:background="@color/spotify_dark_gray"
        android:src="@android:drawable/ic_menu_gallery"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/item_playlist_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Название плейлиста"
        android:textColor="@color/spotify_white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/item_playlist_info"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/item_playlist_cover"
        app:layout_constraintTop_toTopOf="@+id/item_playlist_cover"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/item_playlist_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Плейлист • 0 треков"
        android:textColor="@color/spotify_light_gray"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@+id/item_playlist_cover"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/item_playlist_name"
        app:layout_constraintTop_toBottomOf="@+id/item_playlist_name" />

</androidx.constraintlayout.widget.ConstraintLayout>