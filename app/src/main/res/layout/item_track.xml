<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp"
    android:background="@color/spotify_black">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/item_track_icon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/RoundedImageView"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/item_track_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Название трека"
        android:textColor="@color/spotify_white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:ellipsize="end"
        android:maxLines="1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/item_track_icon"
        app:layout_constraintTop_toTopOf="@+id/item_track_icon" />

    <TextView
        android:id="@+id/item_track_artist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Артист"
        android:textColor="@color/spotify_light_gray"
        android:textSize="14sp"
        android:ellipsize="end"
        android:maxLines="1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/item_track_title"
        app:layout_constraintTop_toBottomOf="@+id/item_track_title" />

</androidx.constraintlayout.widget.ConstraintLayout>