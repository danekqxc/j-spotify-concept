<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/spotify_black"
    tools:context=".MainActivity">

    <!-- Top Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/profile_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_launcher_foreground"
            android:background="@drawable/player_bar_background"
            android:padding="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:contentDescription="Profile" />

        <AutoCompleteTextView
            android:id="@+id/search_bar"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:hint="Поиск"
            android:background="@drawable/player_bar_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/spotify_white"
            android:textColorHint="@color/spotify_light_gray"
            android:textSize="14sp"
            android:completionThreshold="1"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="10dp"
            android:drawableTint="@color/spotify_light_gray"
            app:layout_constraintBottom_toBottomOf="@+id/profile_icon"
            app:layout_constraintEnd_toStartOf="@+id/btn_playlists_list"
            app:layout_constraintStart_toEndOf="@+id/profile_icon"
            app:layout_constraintTop_toTopOf="@+id/profile_icon" />

        <ImageView
            android:id="@+id/btn_playlists_list"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:src="@android:drawable/ic_menu_agenda"
            android:background="@drawable/player_bar_background"
            android:padding="8dp"
            app:tint="@color/spotify_white"
            app:layout_constraintBottom_toBottomOf="@+id/profile_icon"
            app:layout_constraintEnd_toStartOf="@+id/btn_liked_tracks"
            app:layout_constraintTop_toTopOf="@+id/profile_icon" />

        <ImageView
            android:id="@+id/btn_liked_tracks"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_heart"
            android:background="@drawable/player_bar_background"
            android:padding="10dp"
            app:tint="@android:color/holo_red_dark"
            app:layout_constraintBottom_toBottomOf="@+id/profile_icon"
            app:layout_constraintEnd_toStartOf="@+id/btn_add_playlist"
            app:layout_constraintTop_toTopOf="@+id/profile_icon" />

        <ImageView
            android:id="@+id/btn_add_playlist"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_input_add"
            android:background="@drawable/player_bar_background"
            android:padding="8dp"
            app:tint="@color/spotify_white"
            app:layout_constraintBottom_toBottomOf="@+id/profile_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/profile_icon" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Greeting Text -->
    <TextView
        android:id="@+id/main_greeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:text="Добрый день"
        android:textColor="@color/spotify_white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/top_bar" />

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toTopOf="@+id/player_wrapper"
        app:layout_constraintTop_toBottomOf="@+id/main_greeting">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- New Modern Wave Button -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_start_wave"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#333333"
                app:cardBackgroundColor="#1A1A1A">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tv_wave_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Моя волна"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Музыка под настроение"
                        android:textColor="@color/spotify_light_gray"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_wave_label" />

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="@color/spotify_green"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Polished Wave Indicator -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:gravity="bottom"
                        android:orientation="horizontal"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <View android:layout_width="0dp" android:layout_height="12dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/wave_bar_rounded" android:backgroundTint="@color/spotify_green" />
                        <View android:layout_width="0dp" android:layout_height="24dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/wave_bar_rounded" android:backgroundTint="@color/spotify_green" />
                        <View android:layout_width="0dp" android:layout_height="18dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/wave_bar_rounded" android:backgroundTint="@color/spotify_green" />
                        <View android:layout_width="0dp" android:layout_height="30dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/wave_bar_rounded" android:backgroundTint="@color/spotify_green" />
                        <View android:layout_width="0dp" android:layout_height="14dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/wave_bar_rounded" android:backgroundTint="@color/spotify_green" />
                        <View android:layout_width="0dp" android:layout_height="22dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/wave_bar_rounded" android:backgroundTint="@color/spotify_green" />
                        <View android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/wave_bar_rounded" android:backgroundTint="@color/spotify_green" />
                        <View android:layout_width="0dp" android:layout_height="10dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/wave_bar_rounded" android:backgroundTint="@color/spotify_green" />
                        <View android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/wave_bar_rounded" android:backgroundTint="@color/spotify_green" />
                        <View android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/wave_bar_rounded" android:backgroundTint="@color/spotify_green" />
                        <View android:layout_width="0dp" android:layout_height="16dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/wave_bar_rounded" android:backgroundTint="@color/spotify_green" />
                        <View android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/wave_bar_rounded" android:backgroundTint="@color/spotify_green" />
                        <View android:layout_width="0dp" android:layout_height="12dp" android:layout_weight="1" android:background="@drawable/wave_bar_rounded" android:backgroundTint="@color/spotify_green" />

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Selected Artists Section -->
            <TextView
                android:id="@+id/label_my_artists"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:text="Ваши артисты"
                android:textColor="@color/spotify_white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_home_artists"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:clipToPadding="false" />

            <!-- Selected Albums Section -->
            <TextView
                android:id="@+id/label_my_albums"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:text="Ваши альбомы"
                android:textColor="@color/spotify_white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_home_albums"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:clipToPadding="false" />

            <!-- Recent Section -->
            <TextView
                android:id="@+id/label_recent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="32dp"
                android:text="Недавно прослушанное"
                android:textColor="@color/spotify_white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_recent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:clipToPadding="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <FrameLayout
        android:id="@+id/player_wrapper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        app:layout_constraintBottom_toBottomOf="parent">
        <include layout="@layout/layout_mini_player" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>