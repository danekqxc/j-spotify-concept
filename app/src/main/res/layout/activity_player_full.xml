<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/spotify_black"
    android:padding="24dp">

    <ImageView
        android:id="@+id/btn_close"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_menu_revert"
        android:contentDescription="Close"
        app:tint="@color/spotify_white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Контейнер для обложки или видео -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/media_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_close">

        <ImageView
            android:id="@+id/full_track_icon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/cow"
            android:contentDescription="Track Icon" />

        <com.pierfrancescosoffritti.androidyoutubeplayer.core.player.views.YouTubePlayerView
            android:id="@+id/youtube_player_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/track_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Название трека"
        android:textColor="@color/spotify_white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/btn_favorite"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/media_container" />

    <TextView
        android:id="@+id/track_artist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Исполнитель"
        android:textColor="@color/spotify_light_gray"
        android:textSize="18sp"
        app:layout_constraintEnd_toStartOf="@+id/btn_favorite"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/track_title" />

    <ImageView
        android:id="@+id/btn_favorite"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_heart"
        android:contentDescription="Favorite"
        app:tint="@color/spotify_light_gray"
        app:layout_constraintBottom_toBottomOf="@+id/track_artist"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/track_title" />

    <SeekBar
        android:id="@+id/track_seek_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:progressTint="@color/spotify_green"
        android:thumbTint="@color/spotify_green"
        app:layout_constraintTop_toBottomOf="@+id/track_artist" />

    <TextView
        android:id="@+id/time_current"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="0:00"
        android:textColor="@color/spotify_light_gray"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="@+id/track_seek_bar"
        app:layout_constraintTop_toBottomOf="@+id/track_seek_bar" />

    <TextView
        android:id="@+id/time_total"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="3:45"
        android:textColor="@color/spotify_light_gray"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="@+id/track_seek_bar"
        app:layout_constraintTop_toBottomOf="@+id/track_seek_bar" />

    <LinearLayout
        android:id="@+id/controls_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/time_current">

        <ImageView
            android:id="@+id/btn_prev"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="Previous"
            app:tint="@color/spotify_white" />

        <ImageView
            android:id="@+id/btn_play_pause"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginHorizontal="32dp"
            android:background="@drawable/player_bar_background"
            android:padding="16dp"
            android:src="@android:drawable/ic_media_play"
            android:contentDescription="Play/Pause"
            app:tint="@color/spotify_white" />

        <ImageView
            android:id="@+id/btn_next"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_media_next"
            android:contentDescription="Next"
            app:tint="@color/spotify_white" />
    </LinearLayout>

    <ImageView
        android:id="@+id/btn_comments"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:padding="12dp"
        android:src="@android:drawable/stat_notify_chat"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/controls_layout"
        app:tint="@color/spotify_white" />

    <!-- Большая танцующая волна -->
    <LinearLayout
        android:id="@+id/full_wave_container"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginBottom="24dp"
        android:gravity="bottom|center_horizontal"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <View android:id="@+id/wave_bar_f1" android:layout_width="8dp" android:layout_height="20dp" android:layout_marginEnd="4dp" android:background="@color/spotify_green" />
        <View android:id="@+id/wave_bar_f2" android:layout_width="8dp" android:layout_height="40dp" android:layout_marginEnd="4dp" android:background="@color/spotify_green" />
        <View android:id="@+id/wave_bar_f3" android:layout_width="8dp" android:layout_height="15dp" android:layout_marginEnd="4dp" android:background="@color/spotify_green" />
        <View android:id="@+id/wave_bar_f4" android:layout_width="8dp" android:layout_height="60dp" android:layout_marginEnd="4dp" android:background="@color/spotify_green" />
        <View android:id="@+id/wave_bar_f5" android:layout_width="8dp" android:layout_height="25dp" android:layout_marginEnd="4dp" android:background="@color/spotify_green" />
        <View android:id="@+id/wave_bar_f6" android:layout_width="8dp" android:layout_height="45dp" android:layout_marginEnd="4dp" android:background="@color/spotify_green" />
        <View android:id="@+id/wave_bar_f7" android:layout_width="8dp" android:layout_height="30dp" android:layout_marginEnd="4dp" android:background="@color/spotify_green" />
        <View android:id="@+id/wave_bar_f8" android:layout_width="8dp" android:layout_height="55dp" android:layout_marginEnd="4dp" android:background="@color/spotify_green" />
        <View android:id="@+id/wave_bar_f9" android:layout_width="8dp" android:layout_height="20dp" android:layout_marginEnd="4dp" android:background="@color/spotify_green" />
        <View android:id="@+id/wave_bar_f10" android:layout_width="8dp" android:layout_height="40dp" android:background="@color/spotify_green" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>